// Prisma schema for the electronics store.
// Learn more: https://pris.ly/d/prisma-schema
//
// Prisma 7 uses the new `prisma-client` generator. The generated client is
// written to `app/generated/prisma` (git-ignored) and imported from there by
// our singleton in `src/lib/prisma.ts`.

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

// The connection string (DATABASE_URL) is supplied by `prisma.config.ts`,
// which loads it from your `.env` file — so it is intentionally NOT repeated
// here.
datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Catalog
// ---------------------------------------------------------------------------

/// A product category, e.g. "Laptops". Categories can nest via `parent`
/// (a self-relation) so you can model subcategories like "Gaming Laptops".
model Category {
  id       String  @id @default(cuid())
  name     String
  slug     String  @unique // URL-friendly identifier, e.g. "laptops"
  image    String? // optional banner/thumbnail URL

  // Self-relation: a category may have one parent and many children.
  parentId String?
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")

  products  Product[]
  createdAt DateTime  @default(now())

  @@index([parentId])
}

/// A manufacturer / brand, e.g. "Apple" or "Samsung".
model Brand {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  logo     String? // optional logo URL
  products Product[]
}

/// A sellable product. Prices are stored in QAR using a fixed-precision
/// Decimal so money math stays exact (never use Float for currency).
model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String   @db.Text
  price       Decimal  @db.Decimal(10, 2) // amount in QAR
  // Original price, when the item is on sale (used to show a discount badge).
  compareAtPrice Decimal? @db.Decimal(10, 2)
  rating         Float?   // average review rating, e.g. 4.6 (null = no reviews)
  reviewCount    Int      @default(0)
  stock       Int      @default(0)
  featured    Boolean  @default(false) // show on the homepage grid
  specs       Json     @default("{}") // flexible key/value tech specs
  createdAt   DateTime @default(now())
  // Soft delete: set when a product referenced by past orders is "deleted".
  // Such rows are hidden from the storefront and admin list but kept so
  // historical order line items still resolve their product.
  deletedAt   DateTime?

  // Each product belongs to one category and one brand.
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  brandId    String
  brand      Brand    @relation(fields: [brandId], references: [id])

  // One product has many images.
  images        ProductImage[]
  orderItems    OrderItem[]
  cartItems     CartItem[]
  wishlistItems WishlistItem[]

  @@index([categoryId])
  @@index([brandId])
  @@index([deletedAt])
}

/// An image belonging to a product. A product can have several.
model ProductImage {
  id        String  @id @default(cuid())
  url       String
  alt       String? // accessible alt text
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// ---------------------------------------------------------------------------
// Orders (schema only — no checkout logic is built in Phase 1)
// ---------------------------------------------------------------------------

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

/// A customer order. Defined now so the schema is ready for a future
/// checkout phase; nothing writes to it yet.
model Order {
  id              String      @id @default(cuid())
  customerName    String
  customerEmail   String
  customerPhone   String?
  shippingAddress String?
  status          OrderStatus @default(PENDING)
  total           Decimal     @db.Decimal(10, 2) // order total in QAR
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  items           OrderItem[]
  payment         Payment?

  // Optional link to a registered user (guest checkout leaves this null).
  // Populated at checkout, powering the account order history.
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  @@index([userId])
}

/// A single line item within an order. `unitPrice` snapshots the product's
/// price at purchase time so historical orders stay accurate even if the
/// product price later changes.
model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2) // QAR price captured at purchase time

  @@index([orderId])
  @@index([productId])
}

// ---------------------------------------------------------------------------
// Payments (Phase 5)
//
// Payment is processed through a swappable provider interface (see
// src/lib/payments.ts). For the demo the providers are simulated (a test-card
// processor and a BNPL/installment stub); a real provider like Stripe can be
// dropped in behind the same interface. We never store raw card data.
// ---------------------------------------------------------------------------

enum PaymentMethod {
  CARD
  BNPL
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
}

/// A payment against an order. One payment per order for now.
model Payment {
  id        String        @id @default(cuid())
  orderId   String        @unique
  order     Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  method    PaymentMethod
  provider  String // which provider handled it, e.g. "mock-card" / "mock-bnpl"
  reference String // provider transaction reference
  amount    Decimal       @db.Decimal(10, 2) // QAR
  status    PaymentStatus @default(PENDING)
  createdAt DateTime      @default(now())
}

// ---------------------------------------------------------------------------
// Cart & Wishlist (Phase 3–4)
//
// A cart belongs to EITHER an anonymous guest (identified by `sessionToken`
// from the cookie) OR a signed-in user (`userId`). On login the guest cart is
// merged into the user's cart. Both id columns are nullable + unique: Postgres
// allows many NULLs in a unique column, so guests and users don't collide.
// ---------------------------------------------------------------------------

/// A shopping cart, keyed by a guest session token or a user id.
model Cart {
  id           String     @id @default(cuid())
  sessionToken String?    @unique // guest cart: matches the `cart_session` cookie
  userId       String?    @unique // user cart: set after login
  user         User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items        CartItem[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

/// A line item in a cart. One row per product; `quantity` accumulates. The
/// unique constraint guarantees a product appears at most once per cart, so
/// "add again" increments the quantity instead of duplicating the row.
model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)
  createdAt DateTime @default(now())

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
}

/// A saved (wishlisted) product for a guest. Kept flat (keyed directly by the
/// session token) since a wishlist is just a set of products with no quantities.
model WishlistItem {
  id           String   @id @default(cuid())
  sessionToken String // matches the `cart_session` cookie value
  productId    String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@unique([sessionToken, productId])
  @@index([sessionToken])
  @@index([productId])
}

// ---------------------------------------------------------------------------
// Users & Authentication (Phase 4)
//
// Auth is hand-rolled and dependency-free: passwords are hashed with Node's
// built-in scrypt (see src/lib/password.ts), and login state is a server-side
// Session row referenced by an httpOnly cookie (revocable, unlike a bare JWT).
// ---------------------------------------------------------------------------

/// Access levels. `CUSTOMER` shops; `ADMIN`/`SUPERADMIN` gate the admin panel
/// (built in a later phase). Role checks live in src/lib/auth.ts.
enum Role {
  CUSTOMER
  ADMIN
  SUPERADMIN
}

/// A registered user (customer or staff).
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String // scrypt: "salt:derivedKey" (never the raw password)
  name         String
  role         Role      @default(CUSTOMER)
  disabled     Boolean   @default(false) // admins can disable an account
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions Session[]
  cart     Cart?
  orders   Order[]
}

/// A login session. The unguessable `token` is stored in the `session` cookie;
/// deleting the row (or letting it expire) logs the user out everywhere.
model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Admin notifications (Phase 7)
//
// Persisted so the admin dashboard shows recent history; new ones are also
// pushed live over the SSE event bus (see src/lib/events.ts) as they happen.
// ---------------------------------------------------------------------------

enum NotificationKind {
  NEW_ORDER
  LOW_STOCK
}

model Notification {
  id        String           @id @default(cuid())
  kind      NotificationKind
  message   String
  meta      Json             @default("{}") // e.g. { orderId } or { productId, stock }
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([createdAt])
}
