# Copy this file to `.env` and replace the value below with your real
# PostgreSQL connection string (e.g. from Neon). Never commit the real `.env`.
#
# Neon gives you a string that looks like:
#   postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DBNAME?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"
