# Copy this file to `.env` and fill in the value(s) below.
# `.env` is git-ignored — never commit real credentials.

# -----------------------------------------------------------------------------
# DATABASE_URL  (REQUIRED — the only variable the app needs)
# -----------------------------------------------------------------------------
# A PostgreSQL connection string. Neon (https://neon.tech) is a good free option.
# It must be set both at BUILD time and RUNTIME (e.g. in Vercel/Hostinger env
# settings), because the app connects to Postgres on every request.
#
# Neon gives you a string like:
#   postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# -----------------------------------------------------------------------------
# NODE_ENV is set automatically by Next.js / your host — you do NOT need to set
# it. There are no other required environment variables. Payments and the
# real-time layer are self-contained (no API keys).
# -----------------------------------------------------------------------------
